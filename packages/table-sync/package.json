    "test:eslint": "eslint ./src",
    "test:unit": "echo \"skipped\"",
    "test:unit:dev": "echo \"skipped\""
  },
  "dependencies": {
    "radashi": "catalog:"
  },
  "devDependencies": {
    "@tanstack/vite-config": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=16"
  }
}
