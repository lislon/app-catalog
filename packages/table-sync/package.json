{
  "name": "@igstack/app-catalog-table-sync",
  "version": "0.3.0",
  "description": "Database table sync utilities for App Catalog",
  "homepage": "https://github.com/lislon/app-catalog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lislon/app-catalog.git",
    "directory": "packages/table-sync"
  },
  "license": "MIT",
  "author": "Igor Golovin",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "my-custom-condition": "./src/index.ts",
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "clean": "premove ./dist ./coverage ./dist-ts",
    "compile": "tsc --build",
