{
  "name": "@igstack/app-catalog-backend-core",
  "version": "0.3.1-alpha-20260328155123",
  "description": "Backend core library for App Catalog",
  "homepage": "https://github.com/lislon/app-catalog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lislon/app-catalog.git",
    "directory": "packages/backend-core"
  },
  "license": "MIT",
  "author": "Igor Golovin",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "my-custom-condition": "./src/index.ts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "src",
    "prisma",
    "prisma.config.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "build:lenient": "tsdown",
    "clean": "premove ./dist ./coverage ./dist-ts",
    "compile": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "fix": "prettier --write ./src && eslint --fix ./src",
    "prisma:generate": "prisma generate",
    "test:eslint": "eslint ./src --max-warnings=0",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest",
    "test:unit:dev": "pnpm run test:unit --watch"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.25",
    "@better-auth/prisma-adapter": "^1.5.3",
    "@igstack/app-catalog-shared-core": "workspace:*",
    "@igstack/app-catalog-table-sync": "workspace:*",
    "@kubernetes/client-node": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "ai": "^6.0.37",
    "better-auth": "^1.4.18",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "dotenv-defaults": "catalog:",
    "express": "catalog:",
    "jsonwebtoken": "^9.0.2",
    "multer": "catalog:",
    "node-cron": "^4.2.1",
    "radashi": "catalog:",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "tsyringe": "^4.10.0",
    "yaml": "^2.8.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tanstack/vite-config": "catalog:",
    "@types/cors": "^2.8.18",
    "@types/dotenv-defaults": "catalog:",
    "@types/express": "catalog:",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "esbuild": "catalog:",
    "prisma": "catalog:",
    "prisma-json-types-generator": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "pg": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./package.json": "./package.json"
    }
  }
}
