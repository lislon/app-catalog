{
  "name": "@igstack/app-catalog-frontend-build-vite",
  "version": "0.3.1-alpha-20260404005709",
  "description": "Vite build config for App Catalog frontend",
  "homepage": "https://github.com/lislon/app-catalog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lislon/app-catalog.git",
    "directory": "packages/frontend-build-vite"
  },
  "license": "MIT",
  "author": "Igor Golovin",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "my-custom-condition": "./src/index.ts",
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build",
    "build:lenient": "vite build --mode lenient",
    "clean": "premove ./dist ./coverage ./dist-ts",
    "compile": "tsc --build",
    "fix": "prettier --write ./src && eslint --fix ./src",
    "test:eslint": "eslint ./src --max-warnings=0",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vite-plugin-pwa": "catalog:",
    "vite-plugin-static-copy": "catalog:",
    "vite-plugin-svgr": "catalog:"
  },
  "devDependencies": {
    "@igstack/app-catalog-shared-core": "workspace:*",
    "@tanstack/vite-config": "catalog:",
    "@types/node": "catalog:",
    "chokidar": "^5.0.0",
    "esbuild": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "vite": "catalog:",
    "vite-plugin-svgr": "catalog:"
  },
  "engines": {
    "node": ">=16"
  }
}
