{
  "name": "@igstack/app-catalog-source",
  "version": "0.0.0-semantically-released",
  "private": true,
  "license": "MIT",
  "author": "Igor Golovin",
  "type": "module",
  "scripts": {
    "build": "nx run-many -t build --projects=*",
    "build:all": "nx run-many --target=build --exclude=examples/** --exclude=e2e/**",
    "build:all:lenient": "nx run-many --target=build:lenient --exclude=examples/** --exclude=e2e/**",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && pnpm install --no-frozen-lockfile",
    "clean": "pnpm --filter \"./packages/**\" run clean",
    "db:repush": "pnpm run prisma:generate && pnpm run prisma:push && pnpm run db:sync",
    "db:sync": "pnpm --filter @igstack/app-catalog-backend-example run db:sync",
    "dev": "nx run-many -t dev -p @igstack/app-catalog-backend-example,@igstack/app-catalog-frontend-example,@igstack/app-catalog-frontend-core --parallel=3",
    "dev:backend": "nx run-many --target=dev --projects=@igstack/app-catalog-backend-example",
    "dev:frontend": "nx run-many -t dev -p @igstack/app-catalog-frontend-example,@igstack/app-catalog-frontend-core --parallel=2",
    "dev:x": "nx run-many --target=dev --projects=packages/frontend-core",
    "dev:z": "nx run-many -t dev -p 'examples/*,packages/frontend-core' --parallel=10 --nx-ignore-cycles",
    "format": "prettier --write . && nx run-many -t test:eslint --fix --projects=*",
    "preinstall": "node -e \"if(process.env.CI == 'true') {console.info('Skipping preinstall...')} else {process.exit(1)}\" || npx -y only-allow pnpm",
    "kill-all": "node examples/backend-example/kill-all.js",
    "prepare": "husky",
    "prettier": "prettier",
    "prettier:write": "pnpm run prettier --write",
    "prisma:generate": "pnpm --filter @igstack/app-catalog-backend-core prisma:generate",
    "prisma:push": "pnpm --filter @igstack/app-catalog-backend-example exec prisma db push --force-reset --config=../../packages/backend-core/prisma.config.ts",
    "syncpack:fix": "syncpack fix-mismatches",
    "test:build": "publint --strict && attw --ignore-rules no-resolution --pack .",
    "test:ci": "nx run-many --targets=prisma:generate,test:eslint,test:unit,test:types,test:build,build",
    "test:eslint": "nx affected --target=test:eslint",
    "test:frontend": "pnpm --filter @igstack/app-catalog-frontend-core run test:unit",
    "test:pr": "nx affected --targets=prisma:generate,test:eslint,test:unit,test:e2e,test:types,test:build,build",
    "test:syncpack": "syncpack list-mismatches",
    "test:unit": "nx affected --target=test:unit --exclude=examples/**,e2e/**",
    "watch": "pnpm run build:all:lenient && nx watch --all -- nx run \\$NX_PROJECT_NAME:build:lenient",
    "xbuild:all": "nx run-many --target=build --exclude=examples/** --exclude=e2e/**",
    "xtest": "nx run-many -t test --projects=*",
    "xtest:e2e": "nx run-many --target=test:e2e",
    "xtest:format": "pnpm run prettier --check",
    "xtest:types": "nx affected --target=test:types --exclude=examples/**",
    "xtest:unit:dev": "pnpm run test:unit && nx watch --all -- pnpm run test:unit",
    "xverify-links": "node scripts/verify-links.ts"
  },
  "lint-staged": {
    "!(root-symlink.*)*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint  --max-warnings=0 --fix"
    ],
    "*.{json,html,md,css,scss}": [
      "prettier --write"
    ],
    "package.json": [
      "npx sort-package-json"
    ],
    "*": [
      "secretlint"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@prisma/adapter-pg": "7.4.2",
    "dotenv-defaults": "catalog:",
    "pg": "^8.20.0",
    "react-hook-form": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.4",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/eslint-plugin": "^9.2.1",
    "@eslint-react/eslint-plugin": "^1.53.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.4",
    "@tanstack/eslint-config": "catalog:",
    "@tanstack/router-devtools": "^1.151.6",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vitest/eslint-plugin": "^1.3.9",
    "@vitest/ui": "catalog:",
    "commitlint": "^19.8.1",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-unused-imports": "catalog:",
    "fast-glob": "^3.3.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "nx": "21.1.3",
    "premove": "^4.0.0",
    "prettier": "^3.6.2",
    "publint": "^0.3.1",
    "secretlint": "^11.2.4",
    "tsup": "^8.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "@igstack/app-catalog-backend-core": "workspace:*",
      "@igstack/app-catalog-frontend": "workspace:*"
    }
  }
}
