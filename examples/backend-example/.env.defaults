# Default environment variables for backend-example
# These are used if not overridden by .env

# Database - PostgreSQL (requires docker-compose up -d)
# To override, copy .env.postgres to .env and edit
DATABASE_URL=file:./dev.db

# Better Auth
BETTER_AUTH_URL=http://localhost:4001
BETTER_AUTH_SECRET=dev-secret-change-in-production-minimum-32-chars!

# Server
NODE_ENV=development
PORT=4001
