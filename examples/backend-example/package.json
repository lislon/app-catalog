{
  "name": "@igstack/app-catalog-backend-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "clean": "premove ./dist ./coverage ./dist-ts",
    "compile": "tsc --build",
    "db:reset": "rm -f dev.db dev.db-journal",
    "db:reset:postgres": "docker-compose down -v && docker-compose up -d",
    "dev": "tsx watch --conditions=my-custom-condition --include ../../packages/backend-core/src src/index.ts",
    "dev:postgres": "docker-compose up -d && tsx watch src/index.ts",
    "fix": "prettier --write ./src && eslint --fix ./src",
    "prisma:generate": "prisma generate --schema=../../packages/backend-core/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=../../packages/backend-core/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../../packages/backend-core/prisma/schema.prisma",
    "start": "node dist/index.js",
    "test:eslint": "eslint ./src",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.11",
    "@igstack/app-catalog-backend-core": "2.0.1-alpha-20260224192214",
    "@igstack/app-catalog-shared-core": "2.0.1-alpha-20260224192214",
    "@prisma/client": "catalog:",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "cross-env": "catalog:",
    "dotenv-defaults": "catalog:",
    "express": "catalog:",
    "radashi": "catalog:",
    "rand-seed": "^3.0.0"
  },
  "devDependencies": {
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "prisma": "catalog:",
    "prisma-json-types-generator": "catalog:",
    "tsdown": "catalog:",
    "tsup": "^8.5.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-node": "catalog:",
    "vitest": "catalog:",
    "zod-prisma-types": "^3.3.10"
  }
}
