{
  "$schema": "https://unpkg.com/@changesets/config@3.1.2/schema.json",
  "changelog": [
    "@changesets/changelog-github",
    { "repo": "lislon/app-catalog" }
  ],
  "commit": false,
  "fixed": [["@igstack/app-catalog-*"]],
  "linked": [],
  "access": "public",
